# Google AI Studio API key for the Gemini Live API.
# Obtain one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_api_key_here

# --- Optional overrides (defaults shown) ---

# Gemini Live model id.
GEMINI_MODEL_ID=gemini-3.1-flash-live-preview

# Prebuilt voice used for audio responses (e.g. Kore, Puck, Charon, Fenrir, Aoede).
GEMINI_VOICE=Kore

# Audio sample rates (Hz). Gemini Live expects 16 kHz input and 24 kHz output.
GEMINI_INPUT_RATE=16000
GEMINI_OUTPUT_RATE=24000

# Sampling temperature for generation.
GEMINI_TEMPERATURE=0.7

# System prompt for the assistant.
GEMINI_SYSTEM_PROMPT=You are a helpful, concise voice assistant.

# Directory used to persist conversation sessions. Leave blank for a temp dir.
SESSION_STORAGE_DIR=

# Session id used for conversation persistence. Leave blank to disable session management.
SESSION_ID=

# Log level for the `strands` and application loggers (DEBUG, INFO, WARNING, ...).
LOG_LEVEL=INFO
